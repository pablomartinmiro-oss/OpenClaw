# ===== App =====
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=                              # Generate: openssl rand -base64 32
AUTH_URL=http://localhost:3000                 # Auth.js v5 uses AUTH_URL (set to production domain in prod)
AUTH_SECRET=                                   # Same as NEXTAUTH_SECRET — Auth.js v5 name
AUTH_TRUST_HOST=true                           # Required for proxy/container deployments

# ===== Database =====
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ghl_dashboard

# ===== Redis =====
REDIS_URL=redis://localhost:6379

# ===== GHL OAuth =====
GHL_CLIENT_ID=                                # From GHL Marketplace App
GHL_CLIENT_SECRET=                            # From GHL Marketplace App
GHL_REDIRECT_URI=http://localhost:3000/api/ghl/oauth/callback
GHL_WEBHOOK_SECRET=                            # Optional: HMAC secret for webhook signature verification

# ===== Encryption =====
ENCRYPTION_KEY=                               # Generate: openssl rand -hex 32

# ===== Feature Flags =====
ENABLE_NOTIFICATIONS=true
ENABLE_WEBHOOK_LOGGING=true
ENABLE_MOCK_GHL=false                         # Set true for local dev without GHL connection

# ===== Logging =====
LOG_LEVEL=info                                # debug | info | warn | error
